<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/recipe_background"
    android:fitsSystemWindows="true"
    tools:context=".activities.ProfileActivity">

    <LinearLayout
        android:id="@+id/profileTopContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mi perfil"
            android:textColor="@color/recipe_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="92dp"
                android:layout_height="92dp"
                app:cardBackgroundColor="@color/recipe_surface"
                app:cardCornerRadius="46dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/recipe_outline"
                app:strokeWidth="1dp">

                <ImageView
                    android:id="@+id/imgFotoPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Foto de perfil"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/sym_def_app_icon"
                    tools:srcCompat="@tools:sample/avatars" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtNombreUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre del usuario"
                    android:textColor="@color/recipe_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Nombre Apellido" />

                <TextView
                    android:id="@+id/txtCorreoUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="correo@correo.com"
                    android:textColor="@color/recipe_text_secondary"
                    android:textSize="14sp"
                    tools:text="correo@example.com" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtCantidadRecetas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/recipe_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mis recetas"
                    android:textColor="@color/recipe_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtFavoritas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/recipe_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guardadas"
                    android:textColor="@color/recipe_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarPerfil"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Editar perfil"
                android:textAllCaps="false"
                app:cornerRadius="12dp"
                app:strokeColor="@color/recipe_outline" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCerrarSesion"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Cerrar sesión"
                android:textAllCaps="false"
                app:cornerRadius="12dp"
                app:strokeColor="@color/recipe_outline" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/profileTabsBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/profileTopContent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/tabGuardadas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/txtTabGuardadas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guardadas"
                android:textColor="@color/recipe_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorGuardadas"
                android:layout_width="42dp"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:background="@color/recipe_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabMisRecetas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/txtTabMisRecetas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis recetas"
                android:textColor="@color/recipe_text_secondary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorMisRecetas"
                android:layout_width="42dp"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:background="@color/recipe_primary"
                android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/dividerTabs"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:background="@color/recipe_outline"
        app:layout_constraintTop_toBottomOf="@id/profileTabsBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerProfile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/dividerTabs"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/recipe_surface"
        app:itemIconTint="@color/recipe_primary"
        app:itemTextColor="@color/recipe_text_primary"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/bottom_navigation_profile_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
