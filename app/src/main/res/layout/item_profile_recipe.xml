<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="150dp"
    android:layout_height="205dp"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/recipe_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/recipe_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imgReceta"
            android:layout_width="match_parent"
            android:layout_height="145dp"
            android:contentDescription="Imagen de receta"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground"
            tools:src="@tools:sample/backgrounds/scenic" />

        <TextView
            android:id="@+id/txtNombreReceta"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:padding="8dp"
            android:textColor="@color/recipe_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Receta guardada" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
